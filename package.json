{
  "name": "comet-booster",
  "version": "1.0.0",
  "description": "Multiplayer space game — uWebSockets.js + Phaser 3 + TypeScript",
  "type": "module",
  "scripts": {
    "dev":        "concurrently -n server,vite -c blue,green \"NODE_ENV=development tsx watch server/index.ts\" \"vite\"",
    "dev:server": "NODE_ENV=development tsx watch server/index.ts",
    "dev:client": "vite",
    "build":      "vite build",
    "start":      "NODE_ENV=production tsx server/index.ts",
    "typecheck":  "tsc --noEmit && tsc -p client/tsconfig.json --noEmit"
  },
  "dependencies": {
    "phaser":          "^3.90.0",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.68.0"
  },
  "devDependencies": {
    "@types/node":  "^22.0.0",
    "concurrently": "^9.0.0",
    "tsx":          "^4.0.0",
    "typescript":   "^5.0.0",
    "vite":         "^6.0.0"
  }
}
